# THE Travel Club environment configuration
# Copy to .env and fill in the keys you have. Every value is optional: the
# engine boots with demo + no-key providers when nothing is set. `.env` is
# loaded automatically by `npm start` and `npm run smoke:live`; real
# environment variables always take precedence over this file.

# ── Core / server ────────────────────────────────────────────────────────────
#NODE_ENV=development
#PORT=3000
#REQUEST_LOG_LEVEL=info            # debug | info | warn | error
#MAX_QUERY_LENGTH=120

# ── Auth & CORS ──────────────────────────────────────────────────────────────
# Comma-separated consumer API keys (sent as x-api-key or Bearer). In
# production, presence of API_KEYS enables required auth automatically.
#API_KEYS=
#REQUIRE_API_KEY=false
#ALLOWED_ORIGINS=http://localhost:3000

# ── Caching / rate limiting / resilience ─────────────────────────────────────
#CACHE_TTL_MS=300000
#CACHE_MAX_ENTRIES=1000
#RATE_LIMIT_CAPACITY=120           # per client (API key principal or IP)
#RATE_LIMIT_REFILL_PER_MINUTE=120
#PROVIDER_TIMEOUT_MS=8000
#PROVIDER_FAILURE_THRESHOLD=3
#PROVIDER_COOLDOWN_MS=30000

# ── No-key providers (enabled by default; set =false to disable) ─────────────
#DEMO_PROVIDER_ENABLED=true        # auto-excluded per vertical once a real provider is configured
#DEMO_AFFILIATE_ID=
#AIRPORT_PROVIDER_ENABLED=true     # bundled IATA/ICAO dataset (offline)
#OPENSKY_ENABLED=true              # live tracking; optional login raises rate limits
#OPENSKY_USERNAME=
#OPENSKY_PASSWORD=
#ADSB_ENABLED=true                 # adsb.lol + airplanes.live fallbacks

# ── Key-based providers (registered only when credentials are present) ───────
# Hotelbeds APItude (hotels): https://developer.hotelbeds.com
HOTELBEDS_API_KEY=
HOTELBEDS_SECRET=
#HOTELBEDS_ENV=test                # test | production

# RapidAPI: one key covers every RapidAPI-hosted API you are subscribed to.
# Set RAPIDAPI_KEY once, or override per API below.
RAPIDAPI_KEY=

# AeroDataBox (airport enrichment): https://rapidapi.com/aedbx-aedbx/api/aerodatabox
#AERODATABOX_RAPIDAPI_KEY=

# Sky-Scrapper (live Skyscanner flight prices): https://rapidapi.com/apiheya/api/sky-scrapper
#SKYSCRAPPER_RAPIDAPI_KEY=

# Booking.com (hotels): https://rapidapi.com/DataCrawler/api/booking-com15
#BOOKINGCOM_RAPIDAPI_KEY=

# Booking.com car rentals (cars): https://rapidapi.com/DataCrawler/api/booking-com15
#CARRENTAL_RAPIDAPI_KEY=

# Travelpayouts / Aviasales Data API (cached flight fares)
# https://www.travelpayouts.com (requires affiliate-network signup)
TRAVELPAYOUTS_TOKEN=
#TRAVELPAYOUTS_MARKER=

# ── Currency normalization (free, no-key Frankfurter API) ────────────────────
#CURRENCY_CONVERSION_ENABLED=false # true => convert all prices before ranking
#BASE_CURRENCY=USD
#CURRENCY_TTL_MS=3600000

# ── Price memory ("vs. recent average" context + /v1/prices/history) ─────────
#PRICE_HISTORY_ENABLED=true        # false disables recording and the endpoint
#PRICE_HISTORY_FILE=               # e.g. ./data/price-history.jsonl (in-memory only when unset)
#PRICE_HISTORY_MAX_ENTRIES=5000

# ── Price alerts / saved searches (/v1/alerts + background sweep) ────────────
#ALERTS_ENABLED=true               # false disables /v1/alerts and the sweep
#ALERTS_FILE=                      # e.g. ./data/alerts.jsonl (in-memory only when unset)
#ALERTS_MAX_ENTRIES=1000
#ALERTS_CHECK_INTERVAL_MS=300000   # how often the background sweep re-checks watches
#ALERTS_WEBHOOKS_ENABLED=false     # true enables webhook delivery (SSRF-guarded; opt-in)

# ── Accounts, sessions & membership (/v1/auth/* + /v1/me) ────────────────────
#ACCOUNTS_ENABLED=true             # false disables signup/login and /v1/me
#ACCOUNTS_FILE=                    # e.g. ./data/accounts.jsonl (in-memory only when unset)
#ACCOUNTS_MAX_ENTRIES=100000
# Signs stateless session cookies. Set a long random value in production; if
# unset, an ephemeral secret is generated and sessions reset on every restart.
#SESSION_SECRET=
#SESSION_TTL_MS=604800000          # session lifetime (default 7 days)
#COOKIE_SECURE=false               # force the Secure cookie attribute (always on in production)

# ── Managed booking (/v1/orders) ─────────────────────────────────────────────
# Aggregators are the merchant of record. Each adapter runs in a deterministic
# sandbox until its credentials are set, so booking works end to end with no keys.
#BOOKING_ENABLED=true              # false disables /v1/orders
#ORDERS_FILE=                      # e.g. ./data/orders.jsonl (in-memory only when unset)
#ORDERS_MAX_ENTRIES=50000
# Duffel (flight booking): https://duffel.com  (hotels reuse HOTELBEDS_* above)
#DUFFEL_TOKEN=
#DUFFEL_ENV=test                   # test | production

# ── Membership billing (/v1/billing) ─────────────────────────────────────────
# Stripe is the merchant of record for the recurring subscription. Without a
# secret key the gateway runs a deterministic sandbox (subscribe/cancel/webhook
# all work). Set the keys below to go live.
#BILLING_ENABLED=true              # false disables /v1/billing
#STRIPE_SECRET_KEY=                # sk_live_... or sk_test_...
#STRIPE_WEBHOOK_SECRET=            # whsec_...; when set, webhook signatures are verified
#STRIPE_PRICE_SILVER=              # Stripe Price id for the Voyager tier
#STRIPE_PRICE_GOLD=                # Stripe Price id for the Globetrotter tier

# ── Loyalty program (/v1/loyalty) ────────────────────────────────────────────
# Points earned on confirmed bookings (trip total x tier multiplier), redeemed
# for account credit at 100 points per USD.
#LOYALTY_ENABLED=true              # false disables /v1/loyalty
#LOYALTY_FILE=                     # e.g. ./data/loyalty.jsonl (in-memory only when unset)
#LOYALTY_MAX_ENTRIES=100000

# ── Natural-language search assistant (optional, local Ollama) ───────────────
# Turns free text into a SUGGESTED structured search query. Assistive only:
# never wired to pricing, booking, money, or compliance. Off by default.
#ASSISTANT_ENABLED=false           # true enables /v1/assistant + the "Describe your trip" box
#OLLAMA_URL=http://localhost:11434 # your own local Ollama server
#OLLAMA_MODEL=llama3.2
